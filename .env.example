# Base de datos PostgreSQL (Neon)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Secreto para firmar tokens JWT
JWT_SECRET="your-secret-key-here-min-32-characters-long"

# Habilitar restricciones de roles (true/false)
ROLE_RESTRICTIONS_ENABLED="false"

# Configuración SMTP - Microsoft 365 / Office 365
# Remitente: sandra.rodriguezac@ucc.edu.co
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_USER="sandra.rodriguezac@ucc.edu.co"
SMTP_PASS="valor_pendiente_por_configurar"
SMTP_FROM="Portal Gestión de Estudiantes UCC <sandra.rodriguezac@ucc.edu.co>"
