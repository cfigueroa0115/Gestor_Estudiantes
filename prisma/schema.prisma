generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Cargo {
  Profesor
  Jefe
  Administrativo
}

enum Estado {
  Activo
  Inactivo
}

enum Modalidad {
  Presencial
  Virtual
  Funza
}

enum TipoSolicitud {
  Academico    @map("Académico")
  Financiero
  Certificados
}

enum EstadoSolicitud {
  Radicada
  Escalada
  EnProgreso  @map("En progreso")
  Cerrada
}

model Programa {
  id              String    @id @default(uuid()) @db.Uuid
  codigo          String    @unique @db.VarChar(10)
  nombre          String    @db.VarChar(100)
  activo          Boolean   @default(true)
  admin_ids       String[]  @default([])
  email_escalar   String?   @db.VarChar(100)
  created_at      DateTime  @default(now())

  // Relations
  users           User[]    @relation("UserPrograma")

  @@map("programas")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  usuario         String    @unique @db.VarChar(20)
  nombre          String?   @db.VarChar(100)
  password_hash   String
  cargo           Cargo
  organizacion    String?   @db.VarChar(20)
  programa_id     String?   @db.Uuid
  estado          Estado    @default(Activo)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  disabled_at     DateTime?
  last_login_at   DateTime?
  failed_attempts Int       @default(0)
  locked_until    DateTime?
  created_by      String?   @db.Uuid
  updated_by      String?   @db.Uuid

  // Self-referential relations
  creator         User?     @relation("UserCreator", fields: [created_by], references: [id])
  updater         User?     @relation("UserUpdater", fields: [updated_by], references: [id])
  createdUsers    User[]    @relation("UserCreator")
  updatedUsers    User[]    @relation("UserUpdater")

  // Programa relation
  programa        Programa? @relation("UserPrograma", fields: [programa_id], references: [id])

  // Relation to student requests
  studentRequests StudentRequest[] @relation("RequestCreator")
  updatedRequests StudentRequest[] @relation("RequestUpdater")

  @@map("users")
}

model StudentRequest {
  id                     String         @id @default(uuid()) @db.Uuid
  numero_radicado        String         @unique @db.VarChar(20)
  fecha_solicitud        DateTime       @db.Date
  id_estudiante          String         @db.VarChar(10)
  nro_documento          String?        @db.VarChar(20)
  nombres                String         @db.VarChar(100)
  apellidos              String         @db.VarChar(100)
  correo                 String         @db.VarChar(100)
  celular                String         @db.VarChar(15)
  programa               String         @db.VarChar(150)
  modalidad              Modalidad
  tipo_solicitud         TipoSolicitud
  solicitud_academica    String?        @db.VarChar(100)
  solicitud_financiera   String?        @db.VarChar(100)
  descripcion_solicitud  String         @db.VarChar(1200)
  requiere_escalar       Boolean
  area_escalar           String?        @db.VarChar(50)
  estado_solicitud       EstadoSolicitud @default(Radicada)
  estado_solicitud_fecha DateTime       @default(now())
  alerta_vencimiento_enviada Boolean   @default(false)
  observaciones          String?        @db.VarChar(1200)
  gestion_count          Int            @default(0)
  created_by_user_id     String         @db.Uuid
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt
  updated_by             String?        @db.Uuid

  // Relations
  creator                User           @relation("RequestCreator", fields: [created_by_user_id], references: [id], onDelete: Restrict)
  updater                User?          @relation("RequestUpdater", fields: [updated_by], references: [id])

  @@map("student_requests")
}

model Estudiante {
  id                String   @id @default(uuid()) @db.Uuid
  ciclo_lectivo     String?  @db.VarChar(10)
  codigo_sede       String?  @db.VarChar(10)
  programa_academico String? @db.VarChar(10)
  horario           String?  @db.VarChar(10)
  nivel_academico   String?  @db.VarChar(10)
  tipo_admision     String?  @db.VarChar(10)
  desc_tipo_admision String? @db.VarChar(50)
  id_estudiante     String   @unique @db.VarChar(20)
  tipo_documento    String?  @db.VarChar(10)
  nro_documento     String?  @db.VarChar(20)
  primer_apellido   String?  @db.VarChar(50)
  segundo_apellido  String?  @db.VarChar(50)
  apellidos         String?  @db.VarChar(100)
  primer_nombre     String?  @db.VarChar(50)
  segundo_nombre    String?  @db.VarChar(50)
  nombres           String?  @db.VarChar(100)
  genero            String?  @db.VarChar(20)
  telefono          String?  @db.VarChar(20)
  correo            String?  @db.VarChar(100)
  eps               String?  @db.VarChar(100)

  @@map("estudiantes")
}
